<Window x:Class="TopTaskBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TopTaskBar"
        mc:Ignorable="d"
        Title="TopTaskBar"
        Width="800"
        Height="50"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <ContextMenu x:Key="SettingsMenu">
            <MenuItem Header="Window Slot Width" IsEnabled="False" />
            <MenuItem Header="Narrower" Click="OnDecreaseWidthClick" />
            <MenuItem Header="Wider" Click="OnIncreaseWidthClick" />
            <MenuItem Header="Reset Width" Click="OnResetWidthClick" />
            <Separator />
            <MenuItem Header="Refresh Window List" Click="OnRefreshWindowsClick" />
            <Separator />
            <MenuItem Header="Exit TopTaskBar" Click="OnCloseButtonClick" />
        </ContextMenu>
    </Window.Resources>

    <Border Background="{Binding BarBackgroundBrush}"
            BorderBrush="{Binding BarBorderBrush}"
            BorderThickness="0,0,0,1"
            SnapsToDevicePixels="True"
            ContextMenu="{StaticResource SettingsMenu}">
        <Grid Margin="14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Border Width="28"
                        Height="28"
                        CornerRadius="8"
                        Background="{Binding AccentBackgroundBrush}"
                        BorderBrush="{Binding AccentBorderBrush}"
                        BorderThickness="1">
                    <Viewbox>
                        <TextBlock Text="T"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding AccentForegroundBrush}" />
                    </Viewbox>
                </Border>
            </StackPanel>

            <Border Grid.Column="2"
                    Height="40"
                    VerticalAlignment="Center"
                    CornerRadius="20"
                    Background="{Binding AppStripBackgroundBrush}"
                    BorderBrush="{Binding AppStripBorderBrush}"
                    BorderThickness="1">
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0"
                             Width="8"
                             Height="8"
                             VerticalAlignment="Center"
                             Fill="{Binding AccentBorderBrush}" />

                    <ScrollViewer Grid.Column="2"
                                  Grid.ColumnSpan="3"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollBarVisibility="Hidden">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <ItemsControl x:Name="WindowItemsControl"
                                          ItemsSource="{Binding OpenWindows}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:AppWindowInfo}">
                                        <Button Click="OnWindowButtonClick"
                                                Width="{Binding DataContext.WindowSlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Height="30"
                                                Margin="0,0,6,0"
                                                Padding="0"
                                                ToolTip="{Binding Title}"
                                                Background="#0DFFFFFF"
                                                BorderBrush="#18FFFFFF"
                                                BorderThickness="1"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Root"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="9">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#5070E6FF" />
                                                            <Setter TargetName="Root" Property="BorderBrush" Value="#90B7F4FF" />
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#28FFFFFF" />
                                                            <Setter TargetName="Root" Property="BorderBrush" Value="#4AFFFFFF" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#3A67E8F9" />
                                                            <Setter TargetName="Root" Property="BorderBrush" Value="#7099F6FF" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Image Width="22"
                                                   Height="22"
                                                   Source="{Binding Icon}"
                                                   Stretch="Uniform" />
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Height="30"
                                    MinWidth="116"
                                    Padding="12,0"
                                    Background="#0DFFFFFF"
                                    BorderBrush="#18FFFFFF"
                                    BorderThickness="1"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="9">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#28FFFFFF" />
                                                <Setter TargetName="Root" Property="BorderBrush" Value="#4AFFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryForegroundBrush}"
                                           Text="{Binding CurrentDateTimeText}" />
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <StackPanel Grid.Column="3"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Width="26"
                        Height="26"
                        Padding="0"
                        Click="OnSettingsButtonClick"
                        Background="{Binding ChipBackgroundBrush}"
                        BorderBrush="{Binding ChipBorderBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        ToolTip="Right-click for settings"
                        ContextMenu="{StaticResource SettingsMenu}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#28FFFFFF" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#4AFFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="..."
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{Binding PrimaryForegroundBrush}" />
                </Button>

                <Button Margin="8,0,0,0"
                        Width="26"
                        Height="26"
                        Padding="0"
                        Click="OnCloseButtonClick"
                        Background="{Binding ChipBackgroundBrush}"
                        BorderBrush="{Binding ChipBorderBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        ToolTip="Close TopTaskBar">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#4AF87171" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#90FCA5A5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="X"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{Binding PrimaryForegroundBrush}" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
