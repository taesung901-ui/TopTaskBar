<Window x:Class="TopTaskBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TopTaskBar"
        mc:Ignorable="d"
        Title="TopTaskBar"
        Width="800"
        Height="50"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="ToolTipService.InitialShowDelay" Value="50" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="100" />
        </Style>

        <Style x:Key="AlarmToggleSwitchStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}">
                            <Border x:Name="Track"
                                    Background="#88A0A7B4"
                                    CornerRadius="11" />
                            <Border x:Name="Thumb"
                                    Width="18"
                                    Height="18"
                                    Margin="2,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="White"
                                    CornerRadius="9" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#6B6BFF" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.45" />
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ContextMenu x:Key="RunningAppMenu"
                     Opened="OnRunningAppMenuOpened"
                     Closed="OnRunningAppMenuClosed">
            <MenuItem Header="런처에 앱 추가"
                      DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Click="OnAddRunningAppToLauncherClick" />
        </ContextMenu>

        <ContextMenu x:Key="SettingsMenu">
            <MenuItem Header="Window Slot Width" IsEnabled="False" />
            <MenuItem Header="Narrower" Click="OnDecreaseWidthClick" />
            <MenuItem Header="Wider" Click="OnIncreaseWidthClick" />
            <MenuItem Header="Reset Width" Click="OnResetWidthClick" />
            <Separator />
            <MenuItem Header="Refresh Window List" Click="OnRefreshWindowsClick" />
            <Separator />
            <MenuItem Header="Exit TopTaskBar" Click="OnCloseButtonClick" />
        </ContextMenu>
    </Window.Resources>

    <Border Background="{Binding BarBackgroundBrush}"
            BorderBrush="{Binding BarBorderBrush}"
            BorderThickness="0,0,0,1"
            SnapsToDevicePixels="True"
            ContextMenu="{StaticResource SettingsMenu}">
        <Grid Margin="14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Height="40"
                    VerticalAlignment="Center"
                    CornerRadius="20"
                    Background="{Binding AppStripBackgroundBrush}"
                    BorderBrush="{Binding AppStripBorderBrush}"
                    BorderThickness="1">
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0"
                             Width="8"
                             Height="8"
                             VerticalAlignment="Center"
                             Fill="{Binding AccentBorderBrush}" />

                    <ScrollViewer Grid.Column="2"
                                  Grid.ColumnSpan="3"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollBarVisibility="Hidden">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Button x:Name="LauncherButton"
                                    Width="34"
                                    Height="30"
                                    Margin="0,0,6,0"
                                    Padding="0"
                                    PreviewMouseLeftButtonDown="OnLauncherButtonPreviewMouseLeftButtonDown"
                                    Background="{Binding AccentBackgroundBrush}"
                                    BorderBrush="{Binding AccentBorderBrush}"
                                    BorderThickness="1"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="9">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#70FFFFFF" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#90FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="T"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding AccentForegroundBrush}" />
                            </Button>

                            <ItemsControl x:Name="WindowItemsControl"
                                          ItemsSource="{Binding OpenWindows}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:AppWindowInfo}">
                                        <Button Click="OnWindowButtonClick"
                                                Width="{Binding DataContext.WindowSlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Height="30"
                                                Margin="0,0,6,0"
                                                Padding="0"
                                                PreviewMouseRightButtonDown="OnWindowButtonPreviewMouseRightButtonDown"
                                                ContextMenu="{StaticResource RunningAppMenu}"
                                                ToolTip="{Binding Title}"
                                                Background="#12FFFFFF"
                                                BorderBrush="#52FFFFFF"
                                                BorderThickness="1"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Root"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="9">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding HasAttention}" Value="True" />
                                                                <Condition Binding="{Binding IsActive}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter TargetName="Root" Property="Background" Value="#40F59E0B" />
                                                            <Setter TargetName="Root" Property="BorderBrush" Value="#D9F59E0B" />
                                                        </MultiDataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#5070E6FF" />
                                                            <Setter TargetName="Root" Property="BorderBrush" Value="#C0D8F7FF" />
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#28FFFFFF" />
                                                            <Setter TargetName="Root" Property="BorderBrush" Value="#88FFFFFF" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#3A67E8F9" />
                                                            <Setter TargetName="Root" Property="BorderBrush" Value="#B0CFF9FF" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Grid>
                                                <Image Width="22"
                                                       Height="22"
                                                       Source="{Binding Icon}"
                                                       Stretch="Uniform" />
                                                <Ellipse Width="7"
                                                         Height="7"
                                                         Margin="0,0,3,3"
                                                         HorizontalAlignment="Right"
                                                         VerticalAlignment="Top"
                                                         Fill="#FFEF4444"
                                                         Stroke="#CCFFFFFF"
                                                         StrokeThickness="1">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasAttention}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button x:Name="DateTimeButton"
                                    Height="30"
                                    MinWidth="116"
                                    Padding="12,0"
                                    PreviewMouseLeftButtonDown="OnDateTimeButtonPreviewMouseLeftButtonDown"
                                    Background="#0DFFFFFF"
                                    BorderBrush="#18FFFFFF"
                                    BorderThickness="1"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="9">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#28FFFFFF" />
                                                <Setter TargetName="Root" Property="BorderBrush" Value="#4AFFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryForegroundBrush}"
                                           Text="{Binding CurrentDateTimeText}" />
                            </Button>

                            <Popup x:Name="CalendarPopup"
                                   PlacementTarget="{Binding ElementName=DateTimeButton}"
                                   Placement="Bottom"
                                   VerticalOffset="8"
                                   StaysOpen="True"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade"
                                   Opened="OnCalendarPopupOpened"
                                   Closed="OnCalendarPopupClosed">
                                <Border x:Name="CalendarPopupRoot"
                                        Width="364"
                                        Padding="14"
                                        CornerRadius="16"
                                        Background="#E8F3F5F8"
                                        BorderBrush="{Binding BarBorderBrush}"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    Click="OnPreviousMonthClick"
                                                    Background="#10FFFFFF"
                                                    BorderBrush="#24FFFFFF"
                                                    BorderThickness="1"
                                                    Cursor="Hand">
                                                <TextBlock Text="&#x2039;"
                                                           FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding PrimaryForegroundBrush}" />
                                            </Button>

                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       FontSize="18"
                                                       FontWeight="Medium"
                                                       Foreground="{Binding PrimaryForegroundBrush}"
                                                       Text="{Binding DisplayMonthLabel}" />

                                            <Button Grid.Column="2"
                                                    Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    Click="OnNextMonthClick"
                                                    Background="#10FFFFFF"
                                                    BorderBrush="#24FFFFFF"
                                                    BorderThickness="1"
                                                    Cursor="Hand">
                                                <TextBlock Text="&#x203A;"
                                                           FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding PrimaryForegroundBrush}" />
                                            </Button>
                                        </Grid>

                                        <UniformGrid Columns="7"
                                                     Margin="0,0,0,8">
                                            <TextBlock Text="일" TextAlignment="Center" FontWeight="Normal" Foreground="#F87171" />
                                            <TextBlock Text="월" TextAlignment="Center" FontWeight="Normal" Foreground="{Binding MutedForegroundBrush}" />
                                            <TextBlock Text="화" TextAlignment="Center" FontWeight="Normal" Foreground="{Binding MutedForegroundBrush}" />
                                            <TextBlock Text="수" TextAlignment="Center" FontWeight="Normal" Foreground="{Binding MutedForegroundBrush}" />
                                            <TextBlock Text="목" TextAlignment="Center" FontWeight="Normal" Foreground="{Binding MutedForegroundBrush}" />
                                            <TextBlock Text="금" TextAlignment="Center" FontWeight="Normal" Foreground="{Binding MutedForegroundBrush}" />
                                            <TextBlock Text="토" TextAlignment="Center" FontWeight="Normal" Foreground="#60A5FA" />
                                        </UniformGrid>

                                        <ItemsControl ItemsSource="{Binding CalendarDays}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="7" Rows="6" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type local:CalendarDayItem}">
                                                    <Button Margin="2"
                                                            Height="38"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="1"
                                                            Cursor="Arrow"
                                                            IsHitTestVisible="False"
                                                            Focusable="False">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Root"
                                                                        Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="10">
                                                                    <TextBlock x:Name="DayText"
                                                                               Text="{Binding DayText}"
                                                                               FontSize="15"
                                                                               FontWeight="Normal"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Foreground="{Binding DataContext.PrimaryForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                                        <Setter TargetName="DayText" Property="Opacity" Value="0.35" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSunday}" Value="True">
                                                                        <Setter TargetName="DayText" Property="Foreground" Value="#F87171" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSaturday}" Value="True">
                                                                        <Setter TargetName="DayText" Property="Foreground" Value="#60A5FA" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                        <Setter TargetName="Root" Property="Background" Value="{Binding DataContext.AccentBackgroundBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                        <Setter TargetName="Root" Property="BorderBrush" Value="{Binding DataContext.AccentBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                        <Setter TargetName="DayText" Property="Foreground" Value="{Binding DataContext.PrimaryForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                    </DataTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <Popup x:Name="LauncherPopup"
                                   PlacementTarget="{Binding ElementName=LauncherButton}"
                                   Placement="Bottom"
                                   VerticalOffset="8"
                                   StaysOpen="True"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade"
                                   Opened="OnLauncherPopupOpened"
                                   Closed="OnLauncherPopupClosed">
                                <Border x:Name="LauncherPopupRoot"
                                        Width="280"
                                        Padding="14"
                                        CornerRadius="16"
                                        Background="#ECF3F5F8"
                                        BorderBrush="{Binding BarBorderBrush}"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                    <StackPanel>
                                        <TextBlock Text="Launcher"
                                                   FontSize="15"
                                                   FontWeight="Medium"
                                                   Foreground="{Binding PrimaryForegroundBrush}" />

                                        <TextBox x:Name="LauncherSearchBox"
                                                 Margin="0,8,0,0"
                                                 Padding="10,6"
                                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="12"
                                                 Foreground="{Binding PrimaryForegroundBrush}"
                                                 Background="#1AFFFFFF"
                                                 BorderBrush="#5CFFFFFF"
                                                 BorderThickness="1"
                                                 CaretBrush="{Binding PrimaryForegroundBrush}"
                                                 ToolTip="런처 항목 검색" />

                                        <StackPanel Margin="0,10,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasRecentLauncherApps}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <TextBlock Text="Recent"
                                                       Margin="2,0,0,6"
                                                       FontSize="11"
                                                       Foreground="{Binding MutedForegroundBrush}" />

                                            <ItemsControl ItemsSource="{Binding RecentLauncherApps}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type local:LauncherAppItem}">
                                                        <Button Click="OnLauncherAppClick"
                                                                Width="32"
                                                                Height="32"
                                                                Margin="0,0,6,0"
                                                                Padding="0"
                                                                ToolTip="{Binding Name}"
                                                                Background="#12FFFFFF"
                                                                BorderBrush="#36FFFFFF"
                                                                BorderThickness="1"
                                                                Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Root"
                                                                            Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="10">
                                                                        <Grid>
                                                                            <Image Width="16"
                                                                                   Height="16"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Source="{Binding Icon}"
                                                                                   Stretch="Uniform" />
                                                                            <TextBlock Text="{Binding FallbackGlyph}"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       Foreground="{Binding DataContext.PrimaryForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Grid>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Root" Property="Background" Value="#20FFFFFF" />
                                                                            <Setter TargetName="Root" Property="BorderBrush" Value="#54FFFFFF" />
                                                                        </Trigger>
                                                                        <Trigger Property="IsPressed" Value="True">
                                                                            <Setter TargetName="Root" Property="Background" Value="#2AFFFFFF" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <ItemsControl Margin="0,10,0,0"
                                                      ItemsSource="{Binding LauncherApps}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type local:LauncherAppItem}">
                                                    <Button Click="OnLauncherAppClick"
                                                            Margin="0,0,0,4"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Root"
                                                                        Padding="8,4"
                                                                        CornerRadius="12"
                                                                        Background="#10FFFFFF"
                                                                        BorderBrush="#24FFFFFF"
                                                                        BorderThickness="1">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto" />
                                                                            <ColumnDefinition Width="10" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <Border Width="24"
                                                                                Height="24"
                                                                                CornerRadius="8"
                                                                                Background="#16FFFFFF"
                                                                                BorderBrush="#24FFFFFF"
                                                                                BorderThickness="1">
                                                                            <Grid>
                                                                                <Image Width="15"
                                                                                       Height="15"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       Source="{Binding Icon}"
                                                                                       Stretch="Uniform" />
                                                                    <TextBlock Text="{Binding FallbackGlyph}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Foreground="{Binding DataContext.PrimaryForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </Border>

                                                                        <StackPanel Grid.Column="2">
                                                                            <TextBlock Text="{Binding Name}"
                                                                                   FontSize="13"
                                                                                      FontWeight="Medium"
                                                                                       VerticalAlignment="Center"
                                                                                       Foreground="{Binding DataContext.PrimaryForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Root" Property="Background" Value="#18FFFFFF" />
                                                                        <Setter TargetName="Root" Property="BorderBrush" Value="#44FFFFFF" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="Root" Property="Background" Value="#24FFFFFF" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Margin="4,8,4,0"
                                                   Text="검색 결과가 없습니다."
                                                   FontSize="12"
                                                   Foreground="{Binding MutedForegroundBrush}"
                                                   HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsLauncherSearchActive}" Value="True" />
                                                                <Condition Binding="{Binding HasLauncherSearchResults}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Height="34"
                                                    Padding="0"
                                                    Click="OnAddLauncherAppClick"
                                                    Background="#14FFFFFF"
                                                    BorderBrush="#30FFFFFF"
                                                    BorderThickness="1"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Root"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="12">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#1EFFFFFF" />
                                                                <Setter TargetName="Root" Property="BorderBrush" Value="#46FFFFFF" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#28FFFFFF" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="+"
                                                               FontSize="15"
                                                               Margin="0,0,6,0"
                                                               Foreground="{Binding PrimaryForegroundBrush}" />
                                                    <TextBlock Text="앱 추가"
                                                               FontSize="13"
                                                               FontWeight="Medium"
                                                               Foreground="{Binding PrimaryForegroundBrush}" />
                                                </StackPanel>
                                            </Button>

                                            <Button Grid.Column="2"
                                                    Height="34"
                                                    Padding="0"
                                                    Click="OnEditLauncherSettingsClick"
                                                    Background="#14FFFFFF"
                                                    BorderBrush="#30FFFFFF"
                                                    BorderThickness="1"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Root"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="12">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#1EFFFFFF" />
                                                                <Setter TargetName="Root" Property="BorderBrush" Value="#46FFFFFF" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#28FFFFFF" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="{}"
                                                               FontSize="12"
                                                               Margin="0,0,6,0"
                                                               Foreground="{Binding PrimaryForegroundBrush}" />
                                                    <TextBlock Text="JSON 수정"
                                                               FontSize="13"
                                                               FontWeight="Medium"
                                                               Foreground="{Binding PrimaryForegroundBrush}" />
                                                </StackPanel>
                                            </Button>

                                            <Button x:Name="TimerToolButton"
                                                    Grid.Column="4"
                                                    Height="34"
                                                    Padding="0"
                                                    PreviewMouseLeftButtonDown="OnTimerToolButtonPreviewMouseLeftButtonDown"
                                                    ToolTip="타이머/알람 도구"
                                                    Background="#14FFFFFF"
                                                    BorderBrush="#30FFFFFF"
                                                    BorderThickness="1"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Root"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="12">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#1EFFFFFF" />
                                                                <Setter TargetName="Root" Property="BorderBrush" Value="#46FFFFFF" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="#28FFFFFF" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="⏱"
                                                               FontSize="13"
                                                               Margin="0,0,6,0"
                                                               Foreground="{Binding PrimaryForegroundBrush}" />
                                                    <TextBlock Text="타이머"
                                                               FontSize="13"
                                                               FontWeight="Medium"
                                                               Foreground="{Binding PrimaryForegroundBrush}" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <Popup x:Name="TimerToolPopup"
                                               PlacementTarget="{Binding ElementName=TimerToolButton}"
                                               Placement="Top"
                                               VerticalOffset="-8"
                                               HorizontalOffset="0"
                                               StaysOpen="True"
                                               AllowsTransparency="True"
                                               PopupAnimation="Fade"
                                               Opened="OnTimerToolPopupOpened"
                                               Closed="OnTimerToolPopupClosed">
                                            <Border x:Name="TimerToolPopupRoot"
                                                    Width="260"
                                                    Padding="14"
                                                    CornerRadius="16"
                                                    Background="#ECF3F5F8"
                                                    BorderBrush="{Binding BarBorderBrush}"
                                                    BorderThickness="1"
                                                    SnapsToDevicePixels="True">
                                                <StackPanel>
                                                    <UniformGrid Rows="1"
                                                                 Columns="2">
                                                        <Button Height="32"
                                                                Margin="0,0,4,0"
                                                                Click="OnSelectTimerTabClick"
                                                                Background="#14FFFFFF"
                                                                BorderBrush="#30FFFFFF"
                                                                BorderThickness="1"
                                                                Cursor="Hand"
                                                                Content="타이머">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsTimerTabSelected}" Value="True">
                                                                            <Setter Property="Background" Value="#28FFFFFF" />
                                                                            <Setter Property="BorderBrush" Value="#56FFFFFF" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                        <Button Height="32"
                                                                Margin="4,0,0,0"
                                                                Click="OnSelectAlarmTabClick"
                                                                Background="#14FFFFFF"
                                                                BorderBrush="#30FFFFFF"
                                                                BorderThickness="1"
                                                                Cursor="Hand"
                                                                Content="알람">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAlarmTabSelected}" Value="True">
                                                                            <Setter Property="Background" Value="#28FFFFFF" />
                                                                            <Setter Property="BorderBrush" Value="#56FFFFFF" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </UniformGrid>

                                                    <StackPanel Margin="0,12,0,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsTimerTabSelected}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>

                                                    <TextBlock Text="Timer"
                                                               FontSize="15"
                                                               FontWeight="Medium"
                                                               Foreground="{Binding PrimaryForegroundBrush}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding TimerTool.SelectedDurationText, StringFormat=설정 시간 {0}}"
                                                               FontSize="12"
                                                               Foreground="{Binding MutedForegroundBrush}" />
                                                    <TextBlock Margin="0,8,0,0"
                                                               Text="{Binding TimerTool.RemainingTimeText}"
                                                               FontSize="24"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding PrimaryForegroundBrush}" />
                                                    <Grid Margin="0,12,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="분"
                                                                       Margin="2,0,0,4"
                                                                       FontSize="11"
                                                                       Foreground="{Binding MutedForegroundBrush}" />
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="30" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox x:Name="TimerMinutesTextBox"
                                                                         Grid.Column="0"
                                                                         Height="58"
                                                                         VerticalContentAlignment="Center"
                                                                         HorizontalContentAlignment="Center"
                                                                         FontSize="20"
                                                                         FontWeight="SemiBold"
                                                                         Text="05"
                                                                         LostFocus="OnTimerDurationTextBoxLostFocus"
                                                                         KeyDown="OnTimerDurationTextBoxKeyDown"
                                                                         Background="#14FFFFFF"
                                                                         BorderBrush="#30FFFFFF"
                                                                         BorderThickness="1"
                                                                         Foreground="{Binding PrimaryForegroundBrush}"
                                                                         CaretBrush="{Binding PrimaryForegroundBrush}" />
                                                                <Grid Grid.Column="1"
                                                                      Margin="6,0,0,0">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*" />
                                                                        <RowDefinition Height="4" />
                                                                        <RowDefinition Height="*" />
                                                                    </Grid.RowDefinitions>
                                                                    <Button Grid.Row="0"
                                                                            Click="OnTimerMinutesIncreaseClick"
                                                                            Padding="0"
                                                                            Background="#14FFFFFF"
                                                                            BorderBrush="#30FFFFFF"
                                                                            BorderThickness="1"
                                                                            Cursor="Hand"
                                                                            Content="▲" />
                                                                    <Button Grid.Row="2"
                                                                            Click="OnTimerMinutesDecreaseClick"
                                                                            Padding="0"
                                                                            Background="#14FFFFFF"
                                                                            BorderBrush="#30FFFFFF"
                                                                            BorderThickness="1"
                                                                            Cursor="Hand"
                                                                            Content="▼" />
                                                                </Grid>
                                                            </Grid>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="초"
                                                                       Margin="2,0,0,4"
                                                                       FontSize="11"
                                                                       Foreground="{Binding MutedForegroundBrush}" />
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="30" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox x:Name="TimerSecondsTextBox"
                                                                         Grid.Column="0"
                                                                         Height="58"
                                                                         VerticalContentAlignment="Center"
                                                                         HorizontalContentAlignment="Center"
                                                                         FontSize="20"
                                                                         FontWeight="SemiBold"
                                                                         Text="00"
                                                                         LostFocus="OnTimerDurationTextBoxLostFocus"
                                                                         KeyDown="OnTimerDurationTextBoxKeyDown"
                                                                         Background="#14FFFFFF"
                                                                         BorderBrush="#30FFFFFF"
                                                                         BorderThickness="1"
                                                                         Foreground="{Binding PrimaryForegroundBrush}"
                                                                         CaretBrush="{Binding PrimaryForegroundBrush}" />
                                                                <Grid Grid.Column="1"
                                                                      Margin="6,0,0,0">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*" />
                                                                        <RowDefinition Height="4" />
                                                                        <RowDefinition Height="*" />
                                                                    </Grid.RowDefinitions>
                                                                    <Button Grid.Row="0"
                                                                            Click="OnTimerSecondsIncreaseClick"
                                                                            Padding="0"
                                                                            Background="#14FFFFFF"
                                                                            BorderBrush="#30FFFFFF"
                                                                            BorderThickness="1"
                                                                            Cursor="Hand"
                                                                            Content="▲" />
                                                                    <Button Grid.Row="2"
                                                                            Click="OnTimerSecondsDecreaseClick"
                                                                            Padding="0"
                                                                            Background="#14FFFFFF"
                                                                            BorderBrush="#30FFFFFF"
                                                                            BorderThickness="1"
                                                                            Cursor="Hand"
                                                                            Content="▼" />
                                                                </Grid>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Grid>

                                                    <UniformGrid Margin="0,12,0,0"
                                                                 Rows="1"
                                                                 Columns="3">
                                                        <Button Margin="0,0,6,0"
                                                                Height="34"
                                                                Click="OnTimerStartClick"
                                                                IsEnabled="{Binding TimerTool.CanStart}"
                                                                Background="#14FFFFFF"
                                                                BorderBrush="#30FFFFFF"
                                                                BorderThickness="1"
                                                                Cursor="Hand"
                                                                Content="시작" />
                                                        <Button Margin="0,0,6,0"
                                                                Height="34"
                                                                Click="OnTimerPauseClick"
                                                                IsEnabled="{Binding TimerTool.CanPause}"
                                                                Background="#14FFFFFF"
                                                                BorderBrush="#30FFFFFF"
                                                                BorderThickness="1"
                                                                Cursor="Hand"
                                                                Content="중지" />
                                                        <Button Height="34"
                                                                Click="OnTimerResetClick"
                                                                IsEnabled="{Binding TimerTool.CanReset}"
                                                                Background="#14FFFFFF"
                                                                BorderBrush="#30FFFFFF"
                                                                BorderThickness="1"
                                                                Cursor="Hand"
                                                                Content="리셋" />
                                                    </UniformGrid>

                                                    <TextBlock Margin="0,10,0,0"
                                                               Text="{Binding TimerTool.StatusText, StringFormat=상태: {0}}"
                                                               FontSize="12"
                                                               Foreground="{Binding MutedForegroundBrush}" />
                                                    </StackPanel>

                                                    <StackPanel Margin="0,12,0,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAlarmTabSelected}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>

                                                        <TextBlock Margin="0"
                                                                   Visibility="Collapsed"
                                                                   Text="기본 알람 3개를 카드로 표시합니다."
                                                                   FontSize="12"
                                                                   Foreground="{Binding MutedForegroundBrush}" />
                                                        <ItemsControl Margin="0"
                                                                      ItemsSource="{Binding AlarmEntries}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type local:AlarmEntry}">
                                                                    <Border Margin="0,0,0,6"
                                                                            Padding="10"
                                                                            CornerRadius="12"
                                                                            Background="#10FFFFFF"
                                                                            BorderBrush="#24FFFFFF"
                                                                            BorderThickness="1">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Opacity" Value="0.78" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                                        <Setter Property="Opacity" Value="1" />
                                                                                        <Setter Property="Background" Value="#16FFFFFF" />
                                                                                        <Setter Property="BorderBrush" Value="#42FFFFFF" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>

                                                                            <Button Grid.Column="0"
                                                                                    Click="OnEditAlarmClick"
                                                                                    Padding="0"
                                                                                    Background="Transparent"
                                                                                    BorderBrush="Transparent"
                                                                                    BorderThickness="0"
                                                                                    Cursor="Hand"
                                                                                    ToolTip="알람 편집">
                                                                                <Button.Template>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <ContentPresenter />
                                                                                    </ControlTemplate>
                                                                                </Button.Template>
                                                                                <StackPanel HorizontalAlignment="Left">
                                                                                    <TextBlock Text="{Binding Label}"
                                                                                               FontSize="11"
                                                                                               Foreground="{Binding DataContext.MutedForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                                    <StackPanel Margin="0,4,0,0"
                                                                                                Orientation="Horizontal">
                                                                                        <TextBlock Text="{Binding MeridiemText}"
                                                                                                   Margin="0,7,5,0"
                                                                                                   FontSize="12"
                                                                                                   FontWeight="SemiBold"
                                                                                                   Foreground="{Binding DataContext.MutedForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                                        <TextBlock Text="{Binding DisplayTimeText}"
                                                                                                   FontSize="24"
                                                                                                   FontWeight="Light"
                                                                                                   Foreground="{Binding DataContext.PrimaryForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                                    </StackPanel>
                                                                                    <TextBlock Margin="0,4,0,0"
                                                                                               Text="{Binding StatusSummary}"
                                                                                               FontSize="11"
                                                                                               Foreground="{Binding DataContext.MutedForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                                </StackPanel>
                                                                            </Button>

                                                                            <StackPanel Grid.Column="1"
                                                                                        HorizontalAlignment="Right"
                                                                                        VerticalAlignment="Center">
                                                                                <TextBlock Text="클릭해서 편집"
                                                                                           Margin="0,0,0,6"
                                                                                           FontSize="10"
                                                                                           HorizontalAlignment="Right"
                                                                                           Foreground="{Binding DataContext.MutedForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                                <CheckBox IsChecked="{Binding Enabled}"
                                                                                          Checked="OnAlarmEnabledChanged"
                                                                                          Unchecked="OnAlarmEnabledChanged"
                                                                                          Style="{StaticResource AlarmToggleSwitchStyle}"
                                                                                          HorizontalAlignment="Right"
                                                                                          Cursor="Hand"
                                                                                          ToolTip="알람 활성화/비활성화" />
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Popup>

                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Width="26"
                        Height="26"
                        Padding="0"
                        Click="OnSettingsButtonClick"
                        Background="{Binding ChipBackgroundBrush}"
                        BorderBrush="{Binding ChipBorderBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        ToolTip="Right-click for settings"
                        ContextMenu="{StaticResource SettingsMenu}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#28FFFFFF" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#4AFFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="..."
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{Binding PrimaryForegroundBrush}" />
                </Button>

                <Button Margin="8,0,0,0"
                        Width="26"
                        Height="26"
                        Padding="0"
                        Click="OnCloseButtonClick"
                        Background="{Binding ChipBackgroundBrush}"
                        BorderBrush="{Binding ChipBorderBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        ToolTip="Close TopTaskBar">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#4AF87171" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#90FCA5A5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="X"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{Binding PrimaryForegroundBrush}" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
