<Window x:Class="TopTaskBar.TimerCompletedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Timer Complete"
        Width="320"
        Height="180"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    <Border Padding="16"
            CornerRadius="18"
            Background="#ECF3F5F8"
            BorderBrush="#80A8C4D8"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <StackPanel>
            <TextBlock Text="Timer Complete"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#1E2A33" />
            <TextBlock Margin="0,10,0,0"
                       Text="설정한 시간이 끝났습니다."
                       FontSize="13"
                       Foreground="#1E2A33" />
            <TextBlock Margin="0,4,0,0"
                       Text="다시 시작하거나 리셋할 수 있습니다."
                       FontSize="12"
                       Foreground="#5A6875" />
            <Button Margin="0,16,0,0"
                    Height="36"
                    Click="OnConfirmClick"
                    Background="#14FFFFFF"
                    BorderBrush="#30FFFFFF"
                    BorderThickness="1"
                    Cursor="Hand"
                    Content="확인" />
        </StackPanel>
    </Border>
</Window>
